# ============================================================================
# Exemplo de variáveis de ambiente - NUNCA preencha valores reais aqui.
# Copie para .env e preencha com seus valores.
# ============================================================================

# Google Cloud (obrigatório)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-east1
GOOGLE_GENAI_USE_VERTEXAI=1

# Vertex AI Vector Search (preenchido pelo script create_vector_search_index.py)
VECTOR_SEARCH_INDEX_NAME=
VECTOR_SEARCH_INDEX_ENDPOINT_NAME=
# ID do índice implantado no endpoint (default: rag_pdf_deployed)
VECTOR_SEARCH_DEPLOYED_INDEX_ID=rag_pdf_deployed

# Embedding: prioridade Vertex (ADC) se GOOGLE_GENAI_USE_VERTEXAI=1 e GOOGLE_CLOUD_PROJECT definido; senão usa GEMINI_API_KEY
# GEMINI_API_KEY = chave do Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Cloud Storage para upload de PDFs e chunk store (obrigatório para ingestão)
GOOGLE_CLOUD_STORAGE_BUCKET=gcs-spartan-rag
# Opcional: diretório local de PDFs
# PDF_SOURCE_DIR=data/pdfs
